---
/**
 * Office Detail Page — dynamic route for individual BLM offices.
 * Route: /offices/:id (uses blmUnitCode as the id parameter)
 *
 * Loads office data from static JSON (Phase 0) with future Supabase fallback.
 */

import BaseLayout from "@layouts/BaseLayout.astro";
import OfficeMap from "@components/OfficeMap.svelte";
import ExploreChat from "@components/ExploreChat.svelte";
import CommunityConversations from "@components/CommunityConversations.svelte";
import officesData from "@data/blm-offices.json";
import { engagementBadges, officeTypeLabels } from "@lib/badges";
import { getOfficeByUnitCode } from "@lib/supabase/queries";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/offices");
}

const office = officesData.find((o: any) => o.id === id);

if (!office) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

// Look up the Supabase UUID for community conversations
const dbOffice = await getOfficeByUnitCode(id);
const officeUuid = dbOffice?.id ?? null;

const engagement = {
  status: "no-contact",
  updated_at: new Date().toISOString(),
};

const engBadge = engagementBadges[engagement.status as keyof typeof engagementBadges] ?? { label: engagement.status, class: "badge-ghost" };

function isReal(val: unknown): val is string {
  return typeof val === "string" && val.length > 0 && !val.startsWith("TODO");
}
const hasContact = isReal(office.phone) || isReal(office.email);
const hasPlanner = isReal(office.recreationPlannerName);
---

<BaseLayout
  title={`${office.name} — EXPLORE Disc Golf`}
  description={`BLM office detail page for ${office.name}. View contact info, engagement status, and resources for disc golf advocacy.`}
  ogImage="/images/og-offices.png"
>
  <section class="section-padding">
    <div class="content-width">
      <!-- Breadcrumb -->
      <div class="breadcrumbs text-sm mb-6">
        <ul>
          <li><a href="/" class="text-primary">Home</a></li>
          <li><a href="/offices" class="text-primary">Offices</a></li>
          <li class="text-base-content/60">{office.name}</li>
        </ul>
      </div>

      <!-- Office header -->
      <div class="flex flex-col md:flex-row justify-between items-start gap-4 mb-8">
        <div>
          <h1 class="text-3xl font-bold">{office.name}</h1>
          <div class="flex flex-wrap gap-2 mt-2">
            <span class="badge badge-outline">{officeTypeLabels[office.type] ?? office.type}</span>
            <span class="badge badge-ghost">{office.state}</span>
            <span class={`badge ${engBadge.class}`}>
              {engBadge.label}
            </span>
          </div>
        </div>
      </div>

      <div class="grid lg:grid-cols-3 gap-8">
        <!-- Main content -->
        <div class="lg:col-span-2 flex flex-col gap-6">
          <!-- Office boundary map -->
          <div class="card bg-base-200">
            <div class="card-body">
              <h2 class="card-title">Office Boundary</h2>
              <OfficeMap
                client:visible
                officeId={office.id}
                lat={office.lat}
                lng={office.lng}
                officeName={office.name}
              />
            </div>
          </div>

          <!-- What you can do -->
          <div class="card bg-base-200">
            <div class="card-body">
              <h2 class="card-title">How to Engage This Office</h2>
              <div class="space-y-3 text-sm">
                <p>
                  The EXPLORE Act gives BLM new authorities for recreation development.
                  Here's how to start a conversation with {office.name}:
                </p>
                <ol class="list-decimal list-inside space-y-2 ml-2">
                  <li>Download the <a href="/resources/blm-one-pager" class="link link-primary">BLM Executive One-Pager</a> and customize it for this office</li>
                  <li>Review the <a href="/resources/talking-points" class="link link-primary">Talking Points</a> for common concerns</li>
                  <li>Read the <a href="/resources/engagement-strategy" class="link link-primary">Engagement Strategy</a> for meeting request guidance</li>
                  <li>Request a meeting with the Recreation Planner to discuss partnership opportunities</li>
                </ol>
              </div>
            </div>
          </div>

          <!-- Recreation Sites -->
          <div class="card bg-base-200">
            <div class="card-body">
              <h2 class="card-title">Recreation Sites</h2>
              <p class="text-base-content/50 text-sm">
                Recreation site data from BLM ArcGIS will be loaded in Phase 1.
              </p>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="flex flex-col gap-6">
          <!-- Contact info -->
          <div class="card bg-base-200">
            <div class="card-body">
              <h2 class="card-title text-lg">Contact Information</h2>
              <div class="space-y-2 text-sm">
                {office.address && (
                  <div>
                    <span class="font-semibold block text-base-content/60 text-xs uppercase tracking-wide">Address</span>
                    <p>{office.address}</p>
                  </div>
                )}
                {hasContact ? (
                  <>
                    {isReal(office.phone) && (
                      <div>
                        <span class="font-semibold block text-base-content/60 text-xs uppercase tracking-wide">Phone</span>
                        <p>{office.phone}</p>
                      </div>
                    )}
                    {isReal(office.email) && (
                      <div>
                        <span class="font-semibold block text-base-content/60 text-xs uppercase tracking-wide">Email</span>
                        <a href={`mailto:${office.email}`} class="link link-primary">{office.email}</a>
                      </div>
                    )}
                  </>
                ) : (
                  <p class="text-base-content/50 italic">Contact details being researched</p>
                )}
                {hasPlanner && (
                  <div class="mt-3 pt-3 border-t border-base-300">
                    <span class="font-semibold block text-base-content/60 text-xs uppercase tracking-wide">Recreation Planner</span>
                    <p>{office.recreationPlannerName}</p>
                    {isReal(office.recreationPlannerEmail) && (
                      <a href={`mailto:${office.recreationPlannerEmail}`} class="link link-primary text-sm">
                        {office.recreationPlannerEmail}
                      </a>
                    )}
                  </div>
                )}
              </div>
            </div>
          </div>

          <!-- Engagement status -->
          <div class="card bg-base-200">
            <div class="card-body">
              <h2 class="card-title text-lg">Engagement Status</h2>
              <span class={`badge ${engBadge.class} badge-lg`}>
                {engBadge.label}
              </span>
              <p class="text-xs text-base-content/50 mt-1">
                Engagement tracking coming in Phase 2
              </p>
            </div>
          </div>

          <!-- CTA -->
          <div class="card bg-primary text-primary-content">
            <div class="card-body">
              <h2 class="card-title text-lg">Take Action</h2>
              <p class="text-sm opacity-90">
                Explore ideas for disc golf at this office with AI, or download resources.
              </p>
              <a href="#explore" class="btn btn-outline border-primary-content/30 text-primary-content hover:bg-primary-content/10 mt-2">Explore Ideas</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Explore Ideas Chat -->
      <div id="explore" class="mt-10">
        <ExploreChat
          client:visible
          officeId={office.id}
          officeName={office.name}
          officeState={office.state}
        />
      </div>

      <!-- Community Conversations -->
      <div class="mt-12">
        <div class="mb-6">
          <p class="text-sm font-semibold uppercase tracking-wider text-info mb-2">Community</p>
          <h2 class="text-2xl font-bold text-base-content">Community Conversations</h2>
          <p class="text-base-content/60 mt-1">
            See what others have brainstormed about disc golf opportunities at this office.
          </p>
        </div>
        <CommunityConversations client:visible officeUuid={officeUuid} />
      </div>
    </div>
  </section>
</BaseLayout>
