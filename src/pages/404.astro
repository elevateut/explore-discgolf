---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found — EXPLORE Disc Golf" description="The page you're looking for doesn't exist.">
  <section class="section-padding flex items-center justify-center min-h-[60vh]">
    <div class="content-width text-center">
      <p class="text-6xl font-heading font-extrabold text-primary mb-4">404</p>
      <h1 class="text-2xl font-heading font-bold mb-3">Trail not found</h1>
      <p class="text-base-content/70 max-w-md mx-auto mb-8">
        The page you're looking for doesn't exist or has been moved. Let's get you back on the course.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/" class="btn btn-primary">Back to Home</a>
        <a href="/offices" class="btn btn-outline">Find an Office</a>
        <a href="/explore-act" class="btn btn-outline">EXPLORE Act</a>
      </div>
    </div>
  </section>
</BaseLayout>
