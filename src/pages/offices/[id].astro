---
/**
 * Office Detail Page — dynamic route for individual BLM offices.
 *
 * Route: /offices/:id
 *
 * Displays detailed information about a single BLM office including:
 *   - Office name, type, address, contact info
 *   - Map with the office boundary polygon
 *   - Recreation sites managed by this office
 *   - Current engagement status
 *   - "Build My Packet" button to generate an AI-powered proposal
 *
 * Since the site uses SSR (output: "server"), this page renders on each
 * request. For SSG, switch to getStaticPaths() with office data.
 */

import BaseLayout from "@layouts/BaseLayout.astro";
// TODO: Import Supabase query helpers once wired up
// import { getOfficeByUnitCode, getOfficeEngagementStatus } from "@lib/supabase/queries";
// TODO: Import map component for office boundary display
// import OfficeMap from "@components/OfficeMap.svelte";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/offices");
}

// TODO: Fetch office data from Supabase
// const office = await getOfficeByUnitCode(id);
// if (!office) {
//   return new Response("Office not found", { status: 404 });
// }
// const engagement = await getOfficeEngagementStatus(office.id);

// Placeholder data until Supabase is connected
const office = {
  id,
  name: `BLM Office: ${id}`,
  office_type: "field",
  state: "UT",
  address: null as string | null,
  phone: null as string | null,
  email: null as string | null,
  recreation_planner_name: null as string | null,
  recreation_planner_email: null as string | null,
};

const engagement = {
  status: "no-contact",
  updated_at: new Date().toISOString(),
};

/**
 * Status badge color mapping for engagement status.
 */
const statusColors: Record<string, string> = {
  "no-contact": "badge-ghost",
  "initial-outreach": "badge-info",
  "meeting-scheduled": "badge-warning",
  "meeting-completed": "badge-warning",
  "proposal-submitted": "badge-accent",
  "project-active": "badge-success",
  "course-built": "badge-primary",
};
---

<BaseLayout
  title={`${office.name} — EXPLORE Disc Golf`}
  description={`BLM office detail page for ${office.name}. View contact info, engagement status, and generate a proposal packet.`}
>
  <section class="section-padding">
    <div class="content-width">
      <!-- Breadcrumb -->
      <div class="text-sm breadcrumbs mb-6">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/offices">Offices</a></li>
          <li>{office.name}</li>
        </ul>
      </div>

      <!-- Office header -->
      <div class="flex flex-col md:flex-row justify-between items-start gap-4 mb-8">
        <div>
          <h1 class="text-3xl font-bold">{office.name}</h1>
          <div class="flex gap-2 mt-2">
            <span class="badge badge-outline">{office.office_type}</span>
            <span class="badge badge-ghost">{office.state}</span>
            <span class={`badge ${statusColors[engagement.status] ?? "badge-ghost"}`}>
              {engagement.status.replace(/-/g, " ")}
            </span>
          </div>
        </div>
        <div>
          <!-- TODO: Wire up to packet generation action -->
          <button class="btn btn-primary btn-lg">
            Build My Packet
          </button>
        </div>
      </div>

      <div class="grid lg:grid-cols-3 gap-8">
        <!-- Map -->
        <div class="lg:col-span-2">
          <div class="card bg-base-200">
            <div class="card-body">
              <h2 class="card-title">Office Boundary</h2>
              <!-- TODO: Replace with OfficeMap Svelte component showing boundary polygon -->
              <div class="w-full h-[400px] rounded-lg bg-base-300 flex items-center justify-center">
                <span class="text-base-content/50">Map placeholder — boundary for {office.name}</span>
              </div>
            </div>
          </div>

          <!-- Recreation Sites -->
          <div class="card bg-base-200 mt-6">
            <div class="card-body">
              <h2 class="card-title">Recreation Sites</h2>
              <!-- TODO: Fetch and display BLM recreation sites within this office's boundary -->
              <p class="text-base-content/50 italic">
                Recreation site data will be loaded from the BLM ArcGIS MapServer.
              </p>
            </div>
          </div>
        </div>

        <!-- Sidebar: Contact & Engagement -->
        <div class="flex flex-col gap-6">
          <!-- Contact info -->
          <div class="card bg-base-200">
            <div class="card-body">
              <h2 class="card-title text-lg">Contact Information</h2>
              <div class="space-y-2 text-sm">
                {office.address ? (
                  <p><span class="font-semibold">Address:</span> {office.address}</p>
                ) : (
                  <p class="text-base-content/50">Address not yet available</p>
                )}
                {office.phone && (
                  <p><span class="font-semibold">Phone:</span> {office.phone}</p>
                )}
                {office.email && (
                  <p>
                    <span class="font-semibold">Email:</span>{" "}
                    <a href={`mailto:${office.email}`} class="link link-primary">{office.email}</a>
                  </p>
                )}
                {office.recreation_planner_name && (
                  <div class="mt-3 pt-3 border-t border-base-300">
                    <p class="font-semibold">Recreation Planner</p>
                    <p>{office.recreation_planner_name}</p>
                    {office.recreation_planner_email && (
                      <a href={`mailto:${office.recreation_planner_email}`} class="link link-primary text-sm">
                        {office.recreation_planner_email}
                      </a>
                    )}
                  </div>
                )}
              </div>
            </div>
          </div>

          <!-- Engagement status -->
          <div class="card bg-base-200">
            <div class="card-body">
              <h2 class="card-title text-lg">Engagement Status</h2>
              <div class="space-y-2">
                <span class={`badge ${statusColors[engagement.status] ?? "badge-ghost"} badge-lg`}>
                  {engagement.status.replace(/-/g, " ")}
                </span>
                <p class="text-xs text-base-content/50">
                  Last updated: {new Date(engagement.updated_at).toLocaleDateString()}
                </p>
                <!-- TODO: Show engagement history timeline -->
              </div>
            </div>
          </div>

          <!-- Quick actions -->
          <div class="card bg-primary text-primary-content">
            <div class="card-body">
              <h2 class="card-title text-lg">Take Action</h2>
              <p class="text-sm">
                Generate a free, AI-powered proposal packet tailored to this office.
              </p>
              <!-- TODO: Wire up to packet generation Astro Action -->
              <button class="btn btn-ghost mt-2">Build My Packet</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
